#!/usr/bin/env bash
set -Eeuo pipefail

readonly MONITORING_LIBRARY_DIR="/usr/local/lib/gost-manager"
export PYTHONPATH="${MONITORING_LIBRARY_DIR}"
for argument in "$@"; do
  case "${argument}" in
    --policy|--policy=*|--path-root|--path-root=*|--lock-path|--lock-path=*)
      printf 'Error: installed admin policy and lock cannot be overridden.\n' >&2
      exit 2
      ;;
  esac
done
exec python3 -m monitoring.admin_cli --policy installed "$@"
